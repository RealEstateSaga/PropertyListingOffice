/.idea/
/.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build artifacts
/build/

# Node modules (if applicable)
/node_modules/

# Test coverage
/coverage/

# Operating system files
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
